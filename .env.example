# --- Inference (mini-swe-agent via Nebius Token Factory) ---
NEBIUS_API_KEY=XXX

# --- Object Storage (S3-compatible; MinIO by default) ---
# For local/standalone use http://localhost:9000; docker-compose overrides this
# to http://minio:9000 automatically.
S3_BUCKET=mlops-runs
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# --- MLflow ---
# Standalone default is sqlite:///mlflow.db; docker-compose overrides this to
# the MLflow server at http://mlflow:5000.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=swe-bench-eval
